# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=bible_user
DB_PASSWORD=bible_password_123
DB_NAME=bible_db

# CORS (tuỳ chọn) — origin phân tách bằng dấu phẩy; bỏ trống = '*'
# ALLOWED_ORIGINS=https://example.com,https://app.example.com

# Metrics (tuỳ chọn) — nếu set, /api/metrics yêu cầu ?key=<METRICS_KEY>
# METRICS_KEY=change-me

# OpenTelemetry (tuỳ chọn) — bật khi OTEL_ENABLED=true hoặc có endpoint
# OTEL_ENABLED=true
# OTEL_SERVICE_NAME=bible-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
