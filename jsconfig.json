{
  // Cấu hình để VSCode bắt lỗi kiểu ngay trong JavaScript thuần (không cần đổi sang TypeScript).
  // VSCode tự đọc file này. Chạy tay: `npm run typecheck`.
  "compilerOptions": {
    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "checkJs": true, // Bật kiểm tra kiểu cho file .js
    "noEmit": true, // Chỉ kiểm tra, không sinh ra file
    "resolveJsonModule": true, // Cho phép require file .json
    "esModuleInterop": true, // Hiểu đúng require() của thư viện CommonJS (helmet, cors...)
    "strict": false, // Chế độ nhẹ: bắt lỗi rõ ràng (gõ sai tên, sai tham số) nhưng không đòi khai báo kiểu khắp nơi
    "skipLibCheck": true
  },
  // Chỉ kiểm tra code backend (Node). Bỏ qua code chạy trên trình duyệt + HTML.
  "include": ["src/**/*.js"],
  "exclude": ["node_modules", "src/public", "src/views"]
}
