{
  "name": "bible-api",
  "version": "1.0.0",
  "description": "",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "dev": "nest start --watch",
    "start:dev": "nest start --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:up": "docker compose up -d",
    "db:seed": "cat sql/0*.sql | docker exec -i bible_postgres psql -U bible_user -d bible_db",
    "db:reset": "docker compose down -v && docker compose up -d",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@fastify/helmet": "^13.0.2",
    "@fastify/otel": "^0.19.0",
    "@fastify/static": "^9.1.3",
    "@nestjs/cache-manager": "^3.1.3",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-fastify": "^11.1.27",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/throttler": "^6.5.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "cache-manager": "^7.2.9",
    "cacheable": "^2.5.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "nestjs-pino": "^4.6.1",
    "nestjs-zod": "^5.4.0",
    "pg": "^8.17.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@swc/core": "^1.15.43",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.0.18"
  }
}
